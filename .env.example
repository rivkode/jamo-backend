# ===== jamo 로컬 docker compose 환경변수 템플릿 =====
# 사용:  cp .env.example .env  →  값 채우고  →  docker compose up -d
# .env 는 .gitignore 등록됨. 운영 시크릿 절대 커밋 금지.

# ----- Spring profile -----
# LogEmailSender 등 stub 빈은 {local,dev,test,e2e} 한정 — docker 로컬 기동은 dev 사용.
SPRING_PROFILES_ACTIVE=dev

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# ----- Redis -----
REDIS_PORT=6379
REDIS_PASSWORD=jamo-redis-dev

# ----- identity-service -----
IDENTITY_SERVER_PORT=8081
IDENTITY_DB_USERNAME=identity
IDENTITY_DB_PASSWORD=identity-dev
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_WINDOW=PT15M

# ----- diary-service -----
DIARY_SERVER_PORT=8082
DIARY_GRPC_PORT=9092
DIARY_DB_USERNAME=diary
DIARY_DB_PASSWORD=diary-dev
# identity-service 가 호출하는 diary-service gRPC 주소 (프로필 diaryCount, Slice 3-b)
DIARY_SERVICE_GRPC_ADDRESS=static://diary-service:9092

# ----- JWT (LOCAL DEV ONLY) -----
# 키 생성:  ./docker/scripts/generate-dev-keys.sh
# 출력 블록을 그대로 이 파일에 붙여넣기 (PEM 은 multi-line 이중 따옴표 형식).
JWT_ISSUER=https://identity.local.jamoai.app
JWT_AUDIENCE=jamo-services
JWT_KEY_ID=identity-local-k1
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_REFRESH_HASH_PEPPER=

# ----- OAuth providers (LOCAL 가입만 검증할 경우 비워둬도 무방) -----
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Frontend (OAuth redirect 대상) -----
# OAuthBrowserController 의 성공/실패 redirect base. dev 는 Flutter 웹 로컬 서버 (PRD 0526_flutter.md).
FRONTEND_BASE_URL=http://localhost:3000
# Frontend SPA 의 cross-origin API 호출 허용 origin (identity/diary CORS). 쉼표 구분 다중 가능.
# 인증 서비스라 * 미사용 — 명시 origin 만. prod 는 https://jamoai.app.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----- Audio (음성 녹음 저장 — diary-service) -----
# 업로드된 음성 바이너리 로컬 저장 위치 (audio-storage volume 마운트 지점). 운영은 후속 S3.
AUDIO_STORAGE_DIR=/app/audio-storage
